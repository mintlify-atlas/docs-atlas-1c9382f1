  "keyFeatures": [
    "8,000+ cryptocurrency coins with real-time price data",
    "Historical OHLCV data with multiple intervals",
    "Exchange and market information",
    "Smart contract platform integration",
    "Interactive shell (REPL) mode",
    "Multiple output formats (table and JSON)",
